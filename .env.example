# Resend API Key for sending emails
RESEND_API_KEY=re_123456789

# Email where form submissions will be sent
OWNER_EMAIL=hello@pivotai.app

# Email that will appear as the sender
FROM_EMAIL=onboarding@resend.dev

# Supabase service role (server-only) — used by the marketing API routes
# (app/api/demo, app/api/contact) to persist submissions. NEVER expose to the browser.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────────────────────────────────────
# Unified app frontend (consumes the Fastify backend on Render)
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the ai-receptionist-voice backend API.
# Defaults to the production Render deploy if unset.
NEXT_PUBLIC_API_BASE=https://ai-receptionist-voice.onrender.com

# Supabase project URL (public — safe to expose in the browser).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key (public — safe to expose in the browser).
# This is NOT the service-role key. The service-role key stays server-only.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key
